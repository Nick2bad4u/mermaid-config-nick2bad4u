{
    "darkMode": true,
    "deterministicIDSeed": "nick2bad4u-mermaid-config",
    "deterministicIds": true,
    "flowchart": {
        "curve": "basis",
        "diagramPadding": 8,
        "htmlLabels": true,
        "nodeSpacing": 50,
        "padding": 15,
        "rankSpacing": 50,
        "useMaxWidth": true,
        "wrappingWidth": 200
    },
    "fontFamily": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace",
    "fontSize": 14,
    "handDrawnSeed": 1,
    "htmlLabels": true,
    "layout": "dagre",
    "logLevel": "warn",
    "look": "classic",
    "markdownAutoWrap": true,
    "maxEdges": 500,
    "maxTextSize": 50000,
    "secure": [
        "secure",
        "securityLevel",
        "startOnLoad",
        "maxTextSize"
    ],
    "securityLevel": "strict",
    "sequence": {
        "actorMargin": 50,
        "diagramMarginX": 50,
        "diagramMarginY": 10,
        "messageAlign": "center",
        "messageMargin": 35,
        "mirrorActors": true,
        "showSequenceNumbers": false,
        "useMaxWidth": true,
        "wrap": true
    },
    "startOnLoad": true,
    "suppressErrorRendering": false,
    "theme": "base",
    "themeCSS": ".node rect { stroke-width: 2px; } .edgeLabel { border-radius: 3px; padding: 2px 4px; } .cluster rect { stroke-width: 1.5px; stroke-dasharray: 3,3; } .flowchart-link { stroke-width: 2px; }",
    "themeVariables": {
        "actorBkg": "#000000",
        "actorBorder": "#FFFF00",
        "actorLineColor": "#FFFF00",
        "actorTextColor": "#FFFFFF",
        "background": "#000000",
        "edgeLabelBackground": "#000000",
        "lineColor": "#FFFF00",
        "mainBkg": "#000000",
        "primaryBorderColor": "#FFFF00",
        "primaryColor": "#000000",
        "primaryTextColor": "#FFFFFF",
        "secondBkg": "#1A1A1A",
        "secondaryColor": "#1A1A1A",
        "secondaryTextColor": "#FFFFFF",
        "signalColor": "#FFFF00",
        "signalTextColor": "#FFFFFF",
        "tertiaryBkg": "#262626",
        "tertiaryColor": "#262626",
        "tertiaryTextColor": "#FFFFFF",
        "textColor": "#FFFFFF"
    },
    "wrap": true
}
